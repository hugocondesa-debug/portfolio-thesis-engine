        "required": [
          "version",
          "timestamp"
        ],
        "title": "HealthResponse"
      },
      "PipelineRunRequest": {
        "properties": {
          "extraction_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extraction Path"
          },
          "base_period": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Base Period"
          },
