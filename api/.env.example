# PTE API — copy to api/.env (or repo-root .env) and fill in values.
# Both files are gitignored.

PTE_API_USER=hugo
PTE_API_PASSWORD=replace-with-strong-password
PTE_API_LOG_LEVEL=INFO

# Optional — override the docker-compose bind IP if Tailscale assigns
# a different address than 100.70.51.18.
# PTE_API_BIND_HOST=100.70.51.18
